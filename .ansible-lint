# "production" enforces FQCN for modules, no deprecated syntax,
# and all lower-profile rules — appropriate for infra code
profile: production

exclude_paths:
  - .git/
  - .github/

# Rules that are useful to see but shouldn't block CI
warn_list:
  - experimental
