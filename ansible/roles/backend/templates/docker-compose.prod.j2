# Production docker-compose for backend
# Host nginx is used as reverse proxy (not containerized)

name: {{ backend_app_name }}

services:
  app:
    image: {{ backend_docker_image }}:{{ backend_docker_tag }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ backend_app_port }}:8000"
    env_file:
      - {{ backend_shared_dir }}/.env
    volumes:
      - {{ backend_shared_dir }}/staticfiles:/app/staticfiles
      - {{ backend_shared_dir }}/media:/app/media
      - {{ backend_log_dir }}:/app/logs
    labels:
      - "prometheus.io/scrape=true"
      - "prometheus.io/job=guitar0-backend"
      - "prometheus.io/path=/metrics/"
      - "prometheus.io/port=8000"
      - "environment={{ app_env }}"
    networks:
      - default
      - guitar0-network
    depends_on:
      db:
        condition: service_healthy
    deploy:
      resources:
        limits:
          cpus: "1.0"
          memory: 512M
        reservations:
          cpus: "0.25"
          memory: 256M
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/metrics/"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

  db:
    image: postgres:16-alpine
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ backend_db_docker_port }}:5432"
    environment:
      POSTGRES_DB: {{ backend_db_name }}
      POSTGRES_USER: {{ backend_db_user }}
      POSTGRES_PASSWORD: {{ backend_db_password }}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ backend_db_user }}"]
      interval: 10s
      timeout: 5s
      retries: 5

volumes:
  postgres_data:

networks:
  default:
  guitar0-network:
    external: true
