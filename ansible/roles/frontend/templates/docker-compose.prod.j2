# Production docker-compose for frontend (Next.js SSR)
# Host nginx is used as reverse proxy (not containerized)

name: {{ frontend_app_name }}

services:
  app:
    image: {{ frontend_docker_image }}:{{ frontend_docker_tag }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ frontend_app_port }}:3000"
    env_file:
      - {{ frontend_shared_dir }}/.env
    volumes:
      - {{ frontend_log_dir }}:/app/logs
    labels:
      - "prometheus.io/scrape=true"
      - "prometheus.io/path=/metrics"
      - "prometheus.io/port=3000"
      - "environment={{ app_env }}"
    networks:
      - guitar0-network
    deploy:
      resources:
        limits:
          cpus: "1.0"
          memory: 512M
        reservations:
          cpus: "0.25"
          memory: 256M
    healthcheck:
      test: ["CMD", "node", "-e", "require('http').get('http://localhost:3000/', (r) => process.exit(r.statusCode === 200 ? 0 : 1))"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

networks:
  guitar0-network:
    external: true
