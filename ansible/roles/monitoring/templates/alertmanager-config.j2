global:
  resolve_timeout: 5m

route:
  group_by: ["alertname", "severity", "env"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: telegram

receivers:
  - name: telegram
    telegram_configs:
      - bot_token: "{{ telegram_bot_token }}"
        chat_id: {{ telegram_chat_id }}
        parse_mode: HTML
        message: |-
          {{ "{{" }} range .Alerts -{{ "}}" }}
          {{ "{{" }} if eq .Status "firing" {{ "}}" }}🔴{{ "{{" }} else {{ "}}" }}✅{{ "{{" }} end {{ "}}" }} <b>[{{ "{{" }} .Labels.severity | toUpper {{ "}}" }}]{{ "{{" }} with .Labels.env {{ "}}" }}[{{ "{{" }} . | toUpper {{ "}}" }}]{{ "{{" }} end {{ "}}" }} {{ "{{" }} .Annotations.summary {{ "}}" }}</b>
          {{ "{{" }} .Annotations.description {{ "}}" }}
          {{ "{{" }} end {{ "}}" }}

inhibit_rules:
  - source_matchers:
      - alertname=~"Guitar0BackendDown.*"
    target_matchers:
      - alertname=~"Guitar0High.*"
    equal:
      - env
